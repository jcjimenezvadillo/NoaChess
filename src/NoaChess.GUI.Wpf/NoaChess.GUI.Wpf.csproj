<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\NoaChess.Engine\NoaChess.Engine.csproj" />
    <ProjectReference Include="..\NoaChess.Core\NoaChess.Core.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <!-- Piece vector images embedded as WPF resources, addressable via pack:// URIs. -->
    <Resource Include="Resources\Pieces\*.svg" />
    <!-- The repository CHANGELOG, linked (not copied) so the startup dialog
         always shows the current version notes without duplicating the file. -->
    <None Include="..\..\CHANGELOG.md" Link="CHANGELOG.md" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MdXaml" Version="1.27.0" />
    <PackageReference Include="SharpVectors.Wpf" Version="1.8.5" />
  </ItemGroup>

</Project>
