<Window x:Class="NoaChess.GUI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NoaChess.GUI.Wpf.ViewModels"
        Title="NoaChess 2.1.0-dev" Height="640" Width="560"
        MinHeight="400" MinWidth="380">
    <!-- Main window. The DataContext (BoardViewModel) is assigned in code-behind.
         Everything painted comes through bindings: the view never touches the Board. -->
    <DockPanel Margin="8">

        <!-- Top bar: basic game actions -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="New game" Padding="10,4" Click="OnNewGameClicked"/>
            <Button Content="Flip board" Padding="10,4" Margin="8,0,0,0" Click="OnFlipBoardClicked"/>
        </StackPanel>

        <!-- Status bar: game status (turn, check, mate, "thinking...") on the
             left; live engine info (evaluation and search depth in plies,
             updated after each completed iteration) on the right. -->
        <StatusBar DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="13"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding EvaluationText}" FontSize="13" FontWeight="SemiBold"/>
                    <Separator Margin="8,0" Width="1"/>
                    <TextBlock Text="{Binding DepthText}" FontSize="13"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- 8x8 board. Viewbox scales it while keeping it square.
             ItemsControl paints DisplaySquares (already ordered per the
             orientation) onto an 8-column UniformGrid. -->
        <Viewbox Stretch="Uniform">
            <ItemsControl ItemsSource="{Binding DisplaySquares}" Width="480" Height="480">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="8" Columns="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SquareViewModel}">
                        <!-- Each square is a clickable Border. Colors are decided
                             with triggers on the SquareViewModel properties:
                             selection > legal destination > last move > base color. -->
                        <Border MouseLeftButtonDown="OnSquareMouseDown" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <!-- Base color: dark square -->
                                    <Setter Property="Background" Value="#B58863"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLightSquare}" Value="True">
                                            <Setter Property="Background" Value="#F0D9B5"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsLastMove}" Value="True">
                                            <Setter Property="Background" Value="#CDD26A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsLegalTarget}" Value="True">
                                            <Setter Property="Background" Value="#8FBC8F"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="#6699CC"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <!-- Piece image (classic Cburnett set). The source is a
                                 vector DrawingImage built from SVG, so it rescales
                                 losslessly when the board is resized.
                                 Margin 7 on a 60-unit square makes the piece take
                                 ~77% of the square, the proportion used by
                                 chess.com and lichess (75-80%). -->
                            <Image Source="{Binding PieceImage}" Margin="7"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Viewbox>
    </DockPanel>
</Window>
